## .NET + Rider focused .gitignore
## Based on `dotnet new gitignore` + project-specific tuning

# Build output
bin/
obj/
artifacts/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.DotSettings.user
*.slnx.DotSettings.user
*.userprefs

# Visual Studio / Rider
.vs/
.idea/
*.DotSettings.user

# Test results and coverage
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
BenchmarkDotNet.Artifacts/

# MSBuild / dotnet
*.binlog
*.log
*.tlog

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Miscellaneous
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
~$*
*~
*.swp

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db

# =========================
# Project Specific
# =========================

# Local publish output (see publish-local.ps1)
artifacts/

# Rider local history / caches (already mostly covered by .idea/)
.idea/

# Any local test databases or temp files created during development
*.mdf
*.ldf
